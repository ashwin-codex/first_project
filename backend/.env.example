PORT=8000
MONGODB_URI=mongodb://localhost:27017/pocketpilot
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Gemini API configuration (Optional - Falls back to rule-based fallback if empty)
GEMINI_API_KEY=

# Cloudinary configuration (Optional - Falls back to local/memory file uploads if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mail Server Mocking (If empty, emails are logged to server console)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@pocketpilot.com
